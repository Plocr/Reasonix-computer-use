{
  "name": "computer-use",
  "version": "0.1.0",
  "description": "Reasonix computer use plugin - provides Windows GUI automation capabilities",
  "skills": "skills",
  "hooks": {
    "PreToolUse": [
      {
        "command": "hooks/before-action.sh",
        "description": "Safety check before computer use actions"
      }
    ],
    "PostToolUse": [
      {
        "command": "hooks/after-action.sh",
        "description": "Log action and capture screenshot"
      }
    ]
  },
  "mcpServers": {
    "computer-use": {
      "command": "reasonix-computer-use.bat"
    }
  }
}
